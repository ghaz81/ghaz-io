{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "redirects": [
    { "source": "/book", "destination": "https://www.amazon.sg/Bytes-Beyond-Borders-Pakistani-Expatpreneur/dp/6279450023", "permanent": false },
    { "source": "/kindle", "destination": "https://www.amazon.com/Bytes-Beyond-Borders-Pakistani-Expatpreneur-ebook/dp/B0D1KWWW6Z/", "permanent": false },
    { "source": "/linkedin", "destination": "https://www.linkedin.com/in/ghazanfar-iqbal/", "permanent": false }
  ]
}
